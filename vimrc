unlet! skip_defaults_vim
source $VIMRUNTIME/defaults.vim

set relativenumber  " relative line numbers
set ignorecase      " search ignores case
set nowrap          " do not wrap lines, truncate instead
set sidescrolloff=5 " keep 5 columns to the left and right of the cursor
set expandtab       " expands tabs into spaces 
set tabstop=4       " tabs display as 4 spaces
set shiftwidth=4    " indentation set to 4 columns
set softtabstop=4   " soft tab stops are 4 spaces
